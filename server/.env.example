# MongoDB connection string
DATABASE_URL=mongodb://localhost:27017/hiremind_ai?replicaSet=rs0

# JWT configuration
JWT_SECRET=hiremind-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# Google Gemini API key (free at https://aistudio.google.com/apikey)
# AI features won't work without this, but the app will still start
GEMINI_API_KEY=

# Server port
PORT=5001

# Google OAuth (optional — get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
